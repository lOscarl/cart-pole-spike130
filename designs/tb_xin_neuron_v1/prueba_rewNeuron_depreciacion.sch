C {devices/code_shown.sym} -1970 -950 0 0 {name=s2 only_toplevel=false value="
.control
 set num_threads=16
 save vin_pre vout_pre vin_pos vout_pos
 + vin_pre2 vout_pre2 vin_pos2 vout_pos2
 + vin_pre3 vout_pre3 vin_pos3 vout_pos3
 + vin_pre4 vout_pre4 vin_pos4 vout_pos4 
 + i(vmeas1) i(vmeas2) i(vmeas3) i(vmeas4)
 + control vtrh vref v_rew vdd vss
 tran .1n 20u uic
 wrdata prueba_depreciacion.txt vin_pre vout_pre vin_pos vout_pos
 + vin_pre2 vout_pre2 vin_pos2 vout_pos2
 + vin_pre3 vout_pre3 vin_pos3 vout_pos3
 + vin_pre4 vout_pre4 vin_pos4 vout_pos4 
 + i(vmeas1) i(vmeas2) i(vmeas3) i(vmeas4)
 write prueba_rewNeuron_depreciacion.raw
.endc

" }
