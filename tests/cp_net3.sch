Ix 0 v_x 1.8u
Idx 0 v_dx 1.3u
Ith 0 v_th 1u
Idth 0 v_dth 1.5u
Vr1 v_rew1 0 1.8
Vr2 v_rew2 0 1.8
.control

 *save vo_1 vo_2
 *+ n.x7.n1#ngap n.x11.n1#ngap n.x15.n1#ngap n.x19.n1#ngap
 *+ n.x9.n1#ngap n.x13.n1#ngap n.x17.n1#ngap n.x21.n1#ngap
 save all
 tran 10n 20u uic

 wrdata cp_net3.txt vo_1 vo_2
 + n.x7.n1#ngap n.x11.n1#ngap n.x15.n1#ngap n.x19.n1#ngap
 + n.x9.n1#ngap n.x13.n1#ngap n.x17.n1#ngap n.x21.n1#ngap

 write cp_net3.raw

.endc
.save all
" }
